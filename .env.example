# =============================================================================
# Zalo Sales CRM - Biến môi trường
# =============================================================================
# Sao chép file này thành .env và điền thông tin phù hợp:
#   cp .env.example .env

# --- Server ---
PORT=3000
# Địa chỉ bind của server. Mặc định 0.0.0.0 (nghe mọi interface) — phù hợp khi
# chạy trong Docker / sau reverse proxy. Đổi 127.0.0.1 nếu chỉ cho truy cập local.
HOST=0.0.0.0
NODE_ENV=production
# URL công khai, dùng cho links/redirect
APP_URL=https://zalocrm.locnguyendata.com
# URL trang đăng nhập CRM — nhúng vào tin nhắn Zalo notify nội bộ. Default https://crm.example.com
# → deployment khác PHẢI đặt domain của mình.
CRM_LOGIN_URL=https://zalocrm.locnguyendata.com

# --- Bảo mật (BẮT BUỘC — tạo giá trị ngẫu nhiên cho production) ---
# JWT_SECRET: chuỗi ngẫu nhiên, tối thiểu 32 ký tự
#   Tạo: openssl rand -hex 32
JWT_SECRET=

# ENCRYPTION_KEY: đúng 32 bytes (64 hex chars) cho AES-256-GCM
#   Tạo: openssl rand -hex 32
ENCRYPTION_KEY=

# --- Database (PostgreSQL 16+) ---
DB_USER=crmuser
# Bắt buộc: mật khẩu Postgres
DB_PASSWORD=
DB_NAME=zalocrm
DATABASE_URL=postgresql://crmuser:password@db:5432/zalocrm
# Lưu ý: thay "password" trong DATABASE_URL khớp với DB_PASSWORD ở trên

# --- Local Storage (file gốc lưu trên server) ---
UPLOAD_DIR=/var/lib/zalo-crm/files

# --- Redis (event-buffer + cache) ---
# Bỏ comment dòng dưới để bật Redis mode; bỏ trống để dùng in-memory
# Start Redis container: docker compose up -d redis
REDIS_URL=redis://redis:6379

# --- Object/File Storage — chọn driver lưu chat attachments / media ---
#   local (mặc định) → lưu ổ đĩa VPS tại UPLOAD_DIR, serve qua route tĩnh /files.
#                       Chạy ngay, không cần dịch vụ ngoài. Nhớ tự backup ổ đĩa.
#   r2               → lưu Cloudflare R2 (hoặc S3-compatible) qua AWS SDK v3.
STORAGE_DRIVER=local

# [driver local] Public base phục vụ UPLOAD_DIR. Bỏ trống = ${APP_URL}/files.
# Đặt riêng nếu file phục vụ qua host khác (vd Cloudflare Tunnel). KHÔNG có / cuối.
# LOCAL_PUBLIC_URL=https://ee.locnguyendata.com/files

# [driver r2] Cloudflare R2 — chỉ cần khi STORAGE_DRIVER=r2.
# S3_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
# S3_PUBLIC_URL: domain công khai trỏ THẲNG vào bucket (r2.dev / custom domain),
#   KHÔNG kèm tên bucket. Bật public access cho bucket để lấy domain này.
# S3_PUBLIC_URL=https://<public-r2-domain-or-custom-domain>
# S3_BUCKET=<tên bucket R2>
# S3_REGION=auto            # R2 dùng "auto"
# S3_ACCESS_KEY=<r2-access-key-id>
# S3_SECRET_KEY=<r2-secret-access-key>
S3_ENDPOINT=
S3_PUBLIC_URL=
S3_BUCKET=
S3_REGION=auto
S3_ACCESS_KEY=
S3_SECRET_KEY=

# --- Quét virus file upload (ClamAV — TÙY CHỌN, mặc định TẮT) ---
# Quét mọi file/ảnh trước khi lưu. Cần service `clamav` chạy (có trong docker-compose).
# Lần đầu clamav tải DB virus mất vài phút → đợi container 'healthy' rồi mới bật.
#   MEDIA_AV_ENABLED=1  → bật quét. '0'/bỏ trống = tắt.
MEDIA_AV_ENABLED=0
#   MEDIA_AV_FAIL_CLOSED=1 → nếu ClamAV lỗi/không kết nối thì TỪ CHỐI file (an toàn nhất).
#   '0' (mặc định) = fail-open: ClamAV lỗi vẫn cho upload (ưu tiên không gián đoạn).
MEDIA_AV_FAIL_CLOSED=0
# Địa chỉ ClamAV daemon. Mặc định khớp service trong docker-compose.
CLAMAV_HOST=clamav
CLAMAV_PORT=3310

# --- Dọn rác Kho media (cron GC — TÙY CHỌN) ---
# Asset bị bỏ thùng rác quá hạn sẽ bị cron xóa object thật. MẶC ĐỊNH DRY-RUN (chỉ log,
# KHÔNG xóa) cho an toàn. Đặt = 0 để BẬT xóa thật sau khi đã quan sát log ổn.
MEDIA_TRASH_GC_DRYRUN=1

# --- Vận hành / Testing (TÙY CHỌN) ---
# AUTOMATION_STUB_MODE=true → KHÔNG gọi Zalo SDK thật (gửi tin giả lập). Dùng khi test
# luồng automation/broadcast mà không muốn nhắn thật cho khách. Production: false.
AUTOMATION_STUB_MODE=false

# --- Commercial License Key (tùy chọn — dual-license) ---
# ZaloCRM phân phối theo AGPL-3.0 (copyleft mạnh + §13: phân phối lại HOẶC cung cấp dưới dạng
# dịch vụ qua mạng/SaaS — kể cả bản chỉnh sửa — đều phải MỞ MÃ NGUỒN dưới cùng giấy phép).
# Muốn dùng theo điều khoản THƯƠNG MẠI (không chịu copyleft) — dual-license — mua commercial
# license và điền key vào FRIENDS dưới. Liên hệ: locnt@locnguyendata.com
# FRIENDS=

# --- AI — Global defaults ---
# anthropic | gemini | openai | qwen | kimi
AI_DEFAULT_PROVIDER=anthropic
AI_DEFAULT_MODEL=claude-sonnet-4.6

# --- AI Provider: Anthropic ---
ANTHROPIC_BASE_URL=https://api.anthropic.com
# API key từ console.anthropic.com
ANTHROPIC_AUTH_TOKEN=
ANTHROPIC_DEFAULT_OPUS_MODEL=claude-opus-4.6
ANTHROPIC_DEFAULT_SONNET_MODEL=claude-sonnet-4.6
ANTHROPIC_DEFAULT_HAIKU_MODEL=claude-haiku-4.5

# --- AI Provider: Gemini ---
GEMINI_BASE_URL=https://generativelanguage.googleapis.com
# API key từ ai.google.dev
GEMINI_AUTH_TOKEN=
GEMINI_DEFAULT_PRO_MODEL=gemini-1.5-pro
GEMINI_DEFAULT_FLASH_MODEL=gemini-2.5-flash

# --- AI Provider: OpenAI ---
OPENAI_BASE_URL=https://api.openai.com
# API key từ platform.openai.com
OPENAI_AUTH_TOKEN=
OPENAI_DEFAULT_GPT4O_MODEL=gpt-4o
OPENAI_DEFAULT_GPT4O_MINI_MODEL=gpt-4o-mini

# --- AI Provider: Qwen (Alibaba DashScope) ---
QWEN_BASE_URL=https://dashscope.aliyuncs.com
QWEN_AUTH_TOKEN=
QWEN_DEFAULT_PLUS_MODEL=qwen-plus
QWEN_DEFAULT_TURBO_MODEL=qwen-turbo
QWEN_DEFAULT_MAX_MODEL=qwen-max

# --- AI Provider: Kimi (Moonshot) ---
KIMI_BASE_URL=https://api.moonshot.cn
KIMI_AUTH_TOKEN=
KIMI_DEFAULT_MOONSHOT_V1_MODEL=moonshot-v1-8k

# ─── Facebook Lead Ads integration (tùy chọn — chỉ cần nếu dùng FB Lead Ads) ───
# 4 biến (FB_APP_ID/FB_APP_SECRET/FB_WEBHOOK_VERIFY_TOKEN/FB_TOKEN_ENC_KEY) có thể
# điền QUA UI: Settings → Facebook Lead Ads → nút ⚙ Cấu hình (lưu DB per-org).
# Code đọc: DB per-org (UI) → fallback các biến env dưới đây.
# Phiên bản Graph API (không bí mật)
FB_GRAPH_API_VERSION=v21.0
# App ID + App Secret lấy từ developers.facebook.com → App của bạn → Settings → Basic
FB_APP_ID=
FB_APP_SECRET=
# Verify token webhook — tự đặt 1 chuỗi ngẫu nhiên, PHẢI khớp giá trị khai báo
# trong cấu hình Webhook trên Meta App.  Tạo: openssl rand -hex 16
FB_WEBHOOK_VERIFY_TOKEN=
# ⚠️ BẮT BUỘC ở ENV (khoá gốc mã hoá at-rest mọi token tích hợp lưu DB — 32 bytes = 64 hex;
# app THROW nếu thiếu/không đủ 64 hex khi dùng FB). KHÔNG cấu hình qua UI. openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=
# ⚠️ CHỈ đọc từ ENV (UI chỉ hiển thị để copy). PHẢI khai TRÙNG trong Meta App →
# Facebook Login → Valid OAuth Redirect URIs. Thay domain production (localhost OK khi test).
FB_OAUTH_REDIRECT_URI=https://your-domain.com/api/v1/integrations/facebook/oauth/callback
# Luồng "Lead Ads Form" mã hoá page token AES-256-GCM bằng khoá RIÊNG này
# (khác TOKEN_ENCRYPTION_KEY). 64 hex (32 bytes): openssl rand -hex 32
FB_TOKEN_ENC_KEY=

# ─── TikTok Lead Generation (tùy chọn — Nhịp 2, env-gated, mặc định TẮT) ───
# Kéo lead từ quảng cáo TikTok Lead về CRM (Settings → TikTok Lead Gen).
# 4 biến TIKTOK_* có thể điền QUA UI: nút ⚙ Cấu hình (lưu DB per-org, appSecret mã hoá
# bằng TOKEN_ENCRYPTION_KEY ở trên — DÙNG CHUNG). Code đọc: DB per-org (UI) → fallback env.
# App ID + Secret: tạo app tại TikTok for Business → Developer Portal, xin quyền Lead Generation/Marketing API.
TIKTOK_API_VERSION=v1.3
TIKTOK_APP_ID=
TIKTOK_APP_SECRET=
# Verify token webhook (tự đặt, khớp cấu hình TikTok Developer Portal). openssl rand -hex 16
TIKTOK_WEBHOOK_VERIFY_TOKEN=
# Khai TRÙNG trong TikTok App → Redirect URI. Webhook callback URL đăng ký ở Portal:
#   https://your-domain.com/api/v1/webhooks/tiktok-leadgen
TIKTOK_OAUTH_REDIRECT_URI=https://your-domain.com/api/v1/integrations/tiktok/oauth/callback

# ─── Zalo Ads Lead Form integration (tùy chọn — chỉ cần nếu dùng Zalo Form Ads) ───
# Kéo khách hàng tiềm năng từ quảng cáo Zalo Form về CRM (Settings → Zalo Ads Lead Form).
# 3 biến ZALO_OA_* có thể điền QUA UI: nút ⚙ Cấu hình (lưu DB per-org, appSecret mã hoá).
# Code đọc: DB per-org (UI) → fallback các biến env dưới đây. Token OA mã hoá at-rest
# bằng TOKEN_ENCRYPTION_KEY ở trên (DÙNG CHUNG — phải có sẵn 64 hex).
#
# App ID + Secret Key: tạo Ứng dụng tại https://developers.zalo.me → "Ứng dụng của tôi"
#   → tạo app → tab "Thông tin ứng dụng" lấy App ID + Secret Key. Sau đó vào Official
#   Account → liên kết OA + xin quyền nhóm "Quản lý Ads" (để gọi API oa/form/get).
ZALO_OA_APP_ID=
ZALO_OA_APP_SECRET=
# OAuth Redirect URI — Zalo redirect admin OA về đây sau khi cấp quyền (kèm code+oa_id).
#   PHẢI khai TRÙNG trong Zalo App → Đăng nhập (OAuth) → Redirect URI cho phép.
#   Định dạng: <APP_URL>/api/v1/integrations/zalo-ads/oauth/callback
#   (có thể để trống env và điền qua UI ⚙; localhost OK khi test).
ZALO_OA_OAUTH_REDIRECT_URI=https://your-domain.com/api/v1/integrations/zalo-ads/oauth/callback
# Nhịp poll lead (Zalo không có webhook → phải poll định kỳ). Cú pháp cron 5 trường.
#   Mặc định mỗi 5 phút. Để trống = dùng mặc định.
ZALO_POLL_CRON=*/5 * * * *

# ─── Telegram Bridge (tùy chọn — cầu nối chat Zalo ↔ Telegram) ───
# Mỗi nick Zalo được cấp 1 group Telegram (forum/topics) để sale chat qua Telegram.
# Tắt hoàn toàn nếu để trống — code tự bỏ qua khi thiếu biến.
#
# 1) Bot Telegram — tạo qua @BotFather trên Telegram:
#    /newbot → đặt tên + username → BotFather trả về TOKEN.
#    TELEGRAM_BRIDGE_BOT_TOKEN = token đó; TELEGRAM_BRIDGE_BOT_USERNAME = @username (BỎ dấu @).
TELEGRAM_BRIDGE_BOT_TOKEN=
TELEGRAM_BRIDGE_BOT_USERNAME=hs_crm_bridge_bot
#
# 2) Tài khoản Telegram CÔNG TY (MTProto) — để TẠO group (Bot API không tạo group được):
#    - API ID + API HASH: đăng nhập https://my.telegram.org → "API development tools"
#      → tạo app → lấy api_id (số) + api_hash (chuỗi).
TELEGRAM_PROVISIONER_API_ID=
TELEGRAM_PROVISIONER_API_HASH=
#    - SESSION: chuỗi phiên đăng nhập (StringSession) của tài khoản công ty. Đăng nhập 1 LẦN
#      bằng GramJS (api_id+api_hash+số điện thoại+mã OTP) để sinh ra chuỗi này, rồi dán vào đây.
#      ⚠️ BÍ MẬT như mật khẩu — KHÔNG commit. (gitignored trong .env)
TELEGRAM_PROVISIONER_SESSION=

# --- Bảo mật nâng cấp: Token / Tenant / CSP (TÙY CHỌN — có default an toàn) ---
# Tất cả biến dưới đây đều có giá trị mặc định hợp lý; chỉ điền khi muốn đổi.

# Tuổi access token (token ngắn gửi mỗi request). Hết hạn -> FE tự refresh.
#   Rút ngắn (vd 5m) nếu muốn thu hồi tài khoản nhanh hơn. Mặc định: 15m
ACCESS_TOKEN_TTL=15m

# Tuổi refresh token (ms) — sliding, gia hạn mỗi lần xoay. Mặc định: 30 ngày
REFRESH_TOKEN_TTL_MS=2592000000

# Tuổi TUYỆT ĐỐI của 1 phiên đăng nhập (ms) — dù xoay token liên tục cũng không
# vượt hạn này (chống refresh token đánh cắp sống mãi). Mặc định: 90 ngày
REFRESH_FAMILY_MAX_MS=7776000000

# Cửa sổ "grace" (ms) hấp thụ race nhiều tab cùng refresh — tránh đá session oan.
#   Mặc định: 20000 (20 giây)
REFRESH_GRACE_MS=20000

# Cô lập dữ liệu giữa các tổ chức (tenant) ở tầng app:
#   off     = không kiểm tra (mặc định, an toàn để deploy lần đầu)
#   warn    = chỉ GHI LOG khi query thiếu tenant context (dùng trên staging để
#             phát hiện worker/cron chưa wrap withTenant)
#   enforce = CHẶN (throw) — chỉ bật sau khi staging 'warn' sạch + đã apply RLS
TENANT_GUARD_MODE=off

# Content-Security-Policy (chống XSS):
#   report-only = chỉ log vi phạm, KHÔNG chặn (mặc định, an toàn rollout)
#   enforce     = chặn thật (bật sau khi report-only sạch ~vài ngày)
#   off         = tắt CSP header
# Lưu ý: host WebSocket trong CSP tự suy từ APP_URL phía trên — đảm bảo APP_URL đúng.
CSP_MODE=report-only

# Sau khi cutover token (bump jwtTokenVersion toàn bộ + token 7d cũ hết lưu hành),
# đặt true để socket TỪ CHỐI token legacy -> mọi kết nối socket sống tối đa = ACCESS_TOKEN_TTL.
#   Mặc định: false (giai đoạn chuyển tiếp)
SOCKET_REQUIRE_ACCESS_TYP=false

# Gắn app.current_org vào DB connection (cho Postgres RLS đọc tenant hiện hành).
#   false (mặc định) = cơ chế NẰM IM, không đổi hành vi, không overhead.
#   true  = mỗi DB op set app.current_org / app.bypass_rls (SET LOCAL trong transaction).
# CHỈ bật =true trên staging SAU khi đã apply tenant-rls.sql + tạo role app NOSUPERUSER.
RLS_SET_CONFIG=false

# Kill-switch tính năng "đặt nick Riêng tư mới". Mặc định MỞ (cho phép gắn nick private).
#   PRIVACY_LOCK_NEW=1 = KHÓA KHẨN: chặn tạo nick private mới (dùng khi có sự cố quyền riêng tư).
#   bỏ trống/'0' = bình thường.
PRIVACY_LOCK_NEW=0

# ─────────────────────────────────────────────────────────────────────
# Push notification (Firebase FCM/APNs — BE-2 Mobile App)
# ─────────────────────────────────────────────────────────────────────
# LƯU Ý: stack Docker montgomery KHÔNG đọc biến này từ .env. Nó được set
# thẳng trong docker-compose.montgomery.yml (FIREBASE_SERVICE_ACCOUNT_PATH=
# /run/secrets/firebase-sa.json) + mount file secrets/firebase-sa.json (gitignored).
# → Để bật push trên server: đặt file service account vào secrets/firebase-sa.json
#   rồi `docker compose -f docker-compose.montgomery.yml -p montgomery up -d app`.
# Chỉ khi chạy backend TRỰC TIẾP (không Docker) mới cần 1 trong 2 biến dưới.
# Xem: docs/mobile-push-setup-guide.md
# FIREBASE_SERVICE_ACCOUNT_PATH=/run/secrets/firebase-sa.json
# FIREBASE_SERVICE_ACCOUNT_JSON=
