PORT=3000
NODE_ENV=production
APP_URL=https://your-domain.com

# openssl rand -hex 32
JWT_SECRET=
# openssl rand -hex 32
ENCRYPTION_KEY=

DB_USER=crmuser
# PostgreSQL password
DB_PASSWORD=
DB_NAME=zalocrm
DATABASE_URL=postgresql://crmuser:password@db:5432/zalocrm

UPLOAD_DIR=/var/lib/zalo-crm/files

# MinIO local / S3-compatible storage
S3_ENDPOINT=http://minio:9000
S3_PUBLIC_URL=http://localhost:9000
S3_BUCKET=zalocrm-attachments
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# Cloudflare R2 example
# S3_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
# S3_PUBLIC_URL=https://pub-<hash>.r2.dev
# S3_BUCKET=zalocrm-attachments
# S3_REGION=auto
# S3_ACCESS_KEY=<r2-access-key-id>
# S3_SECRET_KEY=<r2-secret-access-key>
# R2 public URL trỏ thẳng vào bucket root → thêm dòng này:
# S3_OMIT_BUCKET_IN_URL=true

# Facebook Lead Ingestion
# Meta App ID
FB_APP_ID=
# Meta App Secret
FB_APP_SECRET=
# Random string set in Meta App Dashboard Webhooks
FB_WEBHOOK_VERIFY_TOKEN=
# 64-char hex, 32 bytes: openssl rand -hex 32
FB_TOKEN_ENC_KEY=
# Example: https://your-domain.com/api/v1/integrations/facebook/oauth/callback
FB_OAUTH_REDIRECT_URI=
# Graph API version
FB_GRAPH_API_VERSION=v23.0

AI_DEFAULT_PROVIDER=anthropic
AI_DEFAULT_MODEL=claude-sonnet-4-6
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
