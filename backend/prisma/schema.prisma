generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Top-level org — every resource is scoped to an org
model Organization {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  teams         Team[]
  users         User[]
  zaloAccounts  ZaloAccount[]
  contacts        Contact[]
  conversations   Conversation[]
  appointments    Appointment[]
  activityLogs    ActivityLog[]
  dailyStats      DailyMessageStat[]
  settings        AppSetting[]
  duplicateGroups DuplicateGroup[]
  savedReports    SavedReport[]
  integrations    Integration[]
  automationRules AutomationRule[]
  messageTemplates MessageTemplate[]
  aiConfig      AiConfig?
  aiSuggestions AiSuggestion[]
  pinnedConversations PinnedConversation[]
  groupPolls          GroupPoll[]
  friendshipAttempts     FriendshipAttempt[]
  friends                Friend[]

  @@map("organizations")
}

// Team groups within an organization
model Team {
  id        String   @id @default(uuid())
  orgId     String   @map("org_id")
  name      String
  createdAt DateTime @default(now()) @map("created_at")

  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  users User[]

  @@map("teams")
}

// CRM user with role-based access
model User {
  id           String   @id @default(uuid())
  orgId        String   @map("org_id")
  teamId       String?  @map("team_id")
  email        String   @unique
  passwordHash String   @map("password_hash")
  fullName     String   @map("full_name")
  role         String   @default("member") // owner, admin, member
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  org              Organization        @relation(fields: [orgId], references: [id], onDelete: Cascade)
  team             Team?               @relation(fields: [teamId], references: [id])
  zaloAccounts     ZaloAccount[]
  zaloAccess       ZaloAccountAccess[]
  assignedContacts Contact[]           @relation("AssignedContacts")
  appointments     Appointment[]
  repliedMessages  Message[]           @relation("RepliedMessages")
  activityLogs     ActivityLog[]
  messageTemplates MessageTemplate[]

  @@map("users")
}

// Zalo account linked to a user (one user may own multiple Zalo accounts)
model ZaloAccount {
  id              String    @id @default(uuid())
  orgId           String    @map("org_id")
  ownerUserId     String    @map("owner_user_id")
  zaloUid         String?   @unique @map("zalo_uid")
  displayName     String?   @map("display_name")
  avatarUrl       String?   @map("avatar_url")
  phone           String?
  status          String    @default("disconnected") // connected, disconnected, qr_pending
  sessionData     Json?     @map("session_data")
  lastConnectedAt DateTime? @map("last_connected_at")
  createdAt       DateTime  @default(now()) @map("created_at")

  org           Organization        @relation(fields: [orgId], references: [id], onDelete: Cascade)
  owner         User                @relation(fields: [ownerUserId], references: [id])
  access        ZaloAccountAccess[]
  conversations Conversation[]
  dailyStats    DailyMessageStat[]
  friendshipAttempts FriendshipAttempt[]
  friends            Friend[]

  @@map("zalo_accounts")
}

// ACL: which users can access which Zalo accounts
model ZaloAccountAccess {
  id            String   @id @default(uuid())
  zaloAccountId String   @map("zalo_account_id")
  userId        String   @map("user_id")
  permission    String   @default("read") // read, chat, admin
  createdAt     DateTime @default(now()) @map("created_at")

  zaloAccount ZaloAccount @relation(fields: [zaloAccountId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([zaloAccountId, userId])
  @@map("zalo_account_access")
}

// CRM contact record — generic pipeline with status field
model Contact {
  id               String    @id @default(uuid())
  orgId            String    @map("org_id")
  zaloUid          String?   @map("zalo_uid")
  phone            String?
  email            String?   @map("email")
  fullName         String?   @map("full_name")
  crmName          String?   @map("crm_name")
  avatarUrl        String?   @map("avatar_url")
  source           String?   // FB, TT, GT, CN, phone_import, etc.
  sourceDate       DateTime? @map("source_date")
  firstContactDate DateTime? @map("first_contact_date")
  status           String?   @default("new") // new/contacted/interested/converted/lost
  nextAppointment  DateTime? @map("next_appointment")
  assignedUserId   String?   @map("assigned_user_id")
  notes            String?
  tags             Json      @default("[]")     // CRM tags do sale gắn ("vip","quan_tam_3pn",...). Auto tag prefix "auto:"
  metadata         Json      @default("{}")
  leadScore        Int       @default(0) @map("lead_score")
  lastActivity     DateTime? @map("last_activity")
  mergedInto       String?   @map("merged_into")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  // ── Discovery via friend-request attempt ─────────────────────────────────
  hasZalo            Boolean?  @map("has_zalo")             // null=unknown, true=verified yes, false=verified no
  zaloLookupAt       DateTime? @map("zalo_lookup_at")
  zaloLookupAttempts Int       @default(0) @map("zalo_lookup_attempts")
  importBatchId      String?   @map("import_batch_id")      // soft FK -> phone_list_imports.id (model later)

  // ── Compliance ─────────────────────────────────────────────────────────────
  consentStatus      String    @default("implicit") @map("consent_status") // implicit/granted/revoked
  consentRevokedAt   DateTime? @map("consent_revoked_at")
  consentSource      String?   @map("consent_source")       // form_landing, opt_in_msg, manual, ...

  // ── Multi-phone ────────────────────────────────────────────────────────────
  phone2             String?   @map("phone_2")
  phone3             String?   @map("phone_3")
  phonesExtra        Json      @default("[]") @map("phones_extra")  // [{phone,label},...]

  // ── Demographic / BĐS profile ──────────────────────────────────────────────
  province           String?
  district           String?
  ward               String?
  addressLine        String?   @map("address_line")
  gender             String?    // male/female/other/unknown
  birthYear          Int?       @map("birth_year")
  birthDate          DateTime? @map("birth_date") @db.Date
  occupation         String?
  incomeRange        String?   @map("income_range")
  socialFacebook     String?   @map("social_facebook")
  socialTiktok       String?   @map("social_tiktok")
  preferredLang      String?   @default("vi") @map("preferred_lang")

  // ── Aggregate: tin nhắn cuối từ KHÁCH (inbound) ───────────────────────────
  lastInboundAt        DateTime? @map("last_inbound_at")
  lastInboundMessageId String?   @map("last_inbound_message_id")
  lastInboundPreview   String?   @map("last_inbound_preview")
  lastInboundType      String?   @map("last_inbound_type")

  // ── Aggregate: tin nhắn cuối từ SALE (outbound) ───────────────────────────
  lastOutboundAt              DateTime? @map("last_outbound_at")
  lastOutboundMessageId       String?   @map("last_outbound_message_id")
  lastOutboundPreview         String?   @map("last_outbound_preview")
  lastOutboundType            String?   @map("last_outbound_type")
  lastOutboundByUserId        String?   @map("last_outbound_by_user_id")        // soft FK
  lastOutboundByZaloAccountId String?   @map("last_outbound_by_zalo_account_id") // soft FK

  // ── Aggregate: tương tác cuối (reaction/recall/edit/...) ──────────────────
  lastInteractionAt      DateTime? @map("last_interaction_at")
  lastInteractionType    String?   @map("last_interaction_type")
  lastInteractionPayload Json?     @map("last_interaction_payload")

  // ── Counters (cache) ───────────────────────────────────────────────────────
  totalInbound       Int       @default(0) @map("total_inbound")
  totalOutbound      Int       @default(0) @map("total_outbound")
  totalAppointments  Int       @default(0) @map("total_appointments")

  org               Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  assignedUser      User?        @relation("AssignedContacts", fields: [assignedUserId], references: [id])
  mergedIntoContact Contact?     @relation("ContactMerge", fields: [mergedInto], references: [id])
  mergedFrom        Contact[]    @relation("ContactMerge")
  conversations     Conversation[]
  appointments      Appointment[]
  attempts          FriendshipAttempt[]
  friends           Friend[]

  // Per-Contact counters (cache from Friend rows; updated by friend-aggregate hooks)
  acceptedNicksCount Int @default(0) @map("accepted_nicks_count")
  pendingNicksCount  Int @default(0) @map("pending_nicks_count")
  chattingNicksCount Int @default(0) @map("chatting_nicks_count")

  @@index([orgId, phone])
  @@index([orgId, zaloUid])
  @@index([orgId, mergedInto])
  @@index([orgId, hasZalo])
  @@index([orgId, importBatchId])
  @@index([orgId, consentStatus])
  @@index([orgId, province, district])
  @@index([orgId, lastInboundAt])
  @@index([orgId, lastOutboundAt])
  @@index([orgId, status, lastInboundAt])
  @@index([phone2])
  @@index([phone3])
  @@index([orgId, acceptedNicksCount])
  @@map("contacts")
}

// A chat thread between a Zalo account and a contact (or group)
model Conversation {
  id               String    @id @default(uuid())
  orgId            String    @map("org_id")
  zaloAccountId    String    @map("zalo_account_id")
  contactId        String?   @map("contact_id")
  threadType       String    @default("user") // user, group
  externalThreadId String?   @map("external_thread_id")
  // Group-specific (chỉ set khi threadType=group; resolve qua getGroupInfo từ zca-js)
  groupName        String?   @map("group_name")
  groupAvatarUrl   String?   @map("group_avatar_url")
  groupMembersCount Int?     @map("group_members_count")
  lastMessageAt    DateTime? @map("last_message_at")
  unreadCount      Int       @default(0) @map("unread_count")
  isReplied        Boolean   @default(true) @map("is_replied")
  tab              String    @default("main") @map("tab") // main, other
  createdAt        DateTime  @default(now()) @map("created_at")

  org           Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  zaloAccount   ZaloAccount   @relation(fields: [zaloAccountId], references: [id], onDelete: Cascade)
  contact       Contact?      @relation(fields: [contactId], references: [id])
  messages      Message[]
  aiSuggestions AiSuggestion[]
  pins          PinnedConversation[]

  @@unique([zaloAccountId, externalThreadId])
  @@index([orgId, zaloAccountId, isReplied, lastMessageAt])
  @@index([orgId, zaloAccountId, lastMessageAt])
  @@index([orgId, tab, lastMessageAt])
  @@map("conversations")
}

// Individual message within a conversation
model Message {
  id              String    @id @default(uuid())
  conversationId  String    @map("conversation_id")
  zaloMsgId       String?   @map("zalo_msg_id")
  senderType      String    @map("sender_type") // self, contact
  senderUid       String?   @map("sender_uid")
  senderName      String?   @map("sender_name")
  content         String?
  contentType     String    @default("text") @map("content_type") // text, image, file, sticker, voice, video, link
  attachments     Json      @default("[]")
  quote           Json?     @map("quote")
  albumKey        String?   @map("album_key")   // Zalo group_layout_id — identifies multi-image albums
  albumIndex      Int?      @map("album_index") // 0-based position within album
  albumTotal      Int?      @map("album_total") // total items in album
  isDeleted       Boolean   @default(false) @map("is_deleted")
  deletedAt       DateTime? @map("deleted_at")
  sentAt          DateTime  @map("sent_at")
  repliedByUserId String?   @map("replied_by_user_id")
  createdAt       DateTime  @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  repliedBy    User?        @relation("RepliedMessages", fields: [repliedByUserId], references: [id])
  reactions    MessageReaction[]

  @@unique([conversationId, zaloMsgId])
  @@index([conversationId, albumKey])
  @@map("messages")
}

// Appointment scheduled for a contact
model Appointment {
  id              String   @id @default(uuid())
  orgId           String   @map("org_id")
  contactId       String   @map("contact_id")
  assignedUserId  String?  @map("assigned_user_id")
  appointmentDate DateTime @map("appointment_date")
  appointmentTime String?  @map("appointment_time")
  type            String?
  status          String   @default("scheduled") // scheduled, completed, cancelled, no_show
  notes           String?
  reminderSent    Boolean  @default(false) @map("reminder_sent")
  createdAt       DateTime @default(now()) @map("created_at")

  org          Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  contact      Contact      @relation(fields: [contactId], references: [id], onDelete: Cascade)
  assignedUser User?        @relation(fields: [assignedUserId], references: [id])

  @@map("appointments")
}

// Audit trail for user actions
model ActivityLog {
  id         String   @id @default(uuid())
  orgId      String   @map("org_id")
  userId     String?  @map("user_id")
  action     String
  entityType String?  @map("entity_type")
  entityId   String?  @map("entity_id")
  details    Json     @default("{}")
  createdAt  DateTime @default(now()) @map("created_at")

  org  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user User?        @relation(fields: [userId], references: [id])

  @@map("activity_logs")
}

// Daily messaging statistics per user per Zalo account
model DailyMessageStat {
  id                String   @id @default(uuid())
  orgId             String   @map("org_id")
  userId            String   @map("user_id")
  zaloAccountId     String   @map("zalo_account_id")
  statDate          DateTime @map("stat_date") @db.Date
  messagesSent      Int      @default(0) @map("messages_sent")
  messagesReceived  Int      @default(0) @map("messages_received")
  messagesUnread    Int      @default(0) @map("messages_unread")
  messagesUnreplied Int      @default(0) @map("messages_unreplied")
  avgResponseTime   Int?     @map("avg_response_time_seconds")

  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  zaloAccount ZaloAccount  @relation(fields: [zaloAccountId], references: [id], onDelete: Cascade)

  @@unique([userId, zaloAccountId, statDate])
  @@map("daily_message_stats")
}

// External service integration (Google Sheets, Telegram, Facebook, Zapier)
model Integration {
  id         String    @id @default(uuid())
  orgId      String    @map("org_id")
  type       String    // google_sheets | telegram | facebook | zapier
  name       String    @default("")
  config     Json      @default("{}") // credentials + settings
  enabled    Boolean   @default(true)
  lastSyncAt DateTime? @map("last_sync_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  org      Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  syncLogs SyncLog[]

  @@map("integrations")
}

// Sync execution log for integrations
model SyncLog {
  id            String   @id @default(uuid())
  integrationId String   @map("integration_id")
  direction     String   // import | export
  recordCount   Int      @default(0) @map("record_count")
  status        String   // success | partial | failed
  errorMessage  String?  @map("error_message")
  createdAt     DateTime @default(now()) @map("created_at")

  integration Integration @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  @@map("sync_logs")
}

// Encrypted or plain key-value settings per org
model AppSetting {
  id             String   @id @default(uuid())
  orgId          String   @map("org_id")
  settingKey     String   @map("setting_key")
  valuePlain     String?  @map("value_plain")
  valueEncrypted Bytes?   @map("value_encrypted")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, settingKey])
  @@map("app_settings")
}

// Groups of potentially duplicate contacts detected by the intelligence cron
model DuplicateGroup {
  id         String   @id @default(uuid())
  orgId      String   @map("org_id")
  contactIds String[] @map("contact_ids")
  matchType  String   @map("match_type") // phone, zalo_uid, name
  confidence Float    @default(1.0)
  resolved   Boolean  @default(false)
  createdAt  DateTime @default(now()) @map("created_at")

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, resolved])
  @@map("duplicate_groups")
}

// Saved analytics report configuration
model SavedReport {
  id        String   @id @default(uuid())
  orgId     String   @map("org_id")
  name      String
  type      String   // conversion_funnel, team_performance, response_time, custom
  config    Json     @default("{}")
  createdBy String   @map("created_by")
  createdAt DateTime @default(now()) @map("created_at")

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@map("saved_reports")
}

model AutomationRule {
  id          String   @id @default(uuid())
  orgId       String   @map("org_id")
  name        String
  description String?
  trigger     String
  conditions  Json     @default("[]")
  actions     Json     @default("[]")
  enabled     Boolean  @default(true)
  priority    Int      @default(0)
  runCount    Int      @default(0) @map("run_count")
  lastRunAt   DateTime? @map("last_run_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, trigger, enabled, priority])
  @@map("automation_rules")
}

model MessageTemplate {
  id          String   @id @default(uuid())
  orgId       String   @map("org_id")
  ownerUserId String?  @map("owner_user_id")
  name        String
  content     String
  category    String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  owner User?        @relation(fields: [ownerUserId], references: [id])

  @@index([orgId, ownerUserId])
  @@index([orgId, category])
  @@map("message_templates")
}

model AiConfig {
  id        String   @id @default(uuid())
  orgId     String   @unique @map("org_id")
  provider  String   @default("anthropic")
  model     String   @default("claude-sonnet-4-6")
  maxDaily  Int      @default(500) @map("max_daily")
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@map("ai_configs")
}

model AiSuggestion {
  id             String    @id @default(uuid())
  orgId          String    @map("org_id")
  conversationId String    @map("conversation_id")
  messageId      String?   @map("message_id")
  type           String
  content        String
  confidence     Float
  accepted       Boolean   @default(false)
  createdAt      DateTime  @default(now()) @map("created_at")

  org          Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([orgId, createdAt])
  @@index([conversationId, createdAt])
  @@index([orgId, type, createdAt])
  @@map("ai_suggestions")
}

// ── Ported from openzca ────────────────────────────────────────────────────

// Emoji reaction on a message (ported from openzca msg react)
model MessageReaction {
  id        String   @id @default(uuid())
  messageId String   @map("message_id")
  reactorId String   @map("reactor_id") // Zalo UID of the person who reacted
  emoji     String   // ❤️ 👍 😆 😮 😭 😡
  createdAt DateTime @default(now()) @map("created_at")

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([messageId, reactorId])
  @@map("message_reactions")
}

// Pinned conversation (ported from openzca msg pin)
model PinnedConversation {
  id             String   @id @default(uuid())
  orgId          String   @map("org_id")
  zaloAccountId  String   @map("zalo_account_id")
  conversationId String   @map("conversation_id")
  pinnedAt       DateTime @default(now()) @map("pinned_at")

  org          Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@unique([zaloAccountId, conversationId])
  @@map("pinned_conversations")
}

// Group poll (ported from openzca group poll)
model GroupPoll {
  id               String    @id @default(uuid())
  orgId            String    @map("org_id")
  zaloAccountId    String    @map("zalo_account_id")
  groupExternalId  String    @map("group_external_id")
  zaloPollId       String    @map("zalo_poll_id")
  question         String
  options          Json      @default("[]") // [{id, text, voteCount}]
  isMultiChoice    Boolean   @default(false) @map("is_multi_choice")
  isAnonymous      Boolean   @default(false) @map("is_anonymous")
  isLocked         Boolean   @default(false) @map("is_locked")
  expiresAt        DateTime? @map("expires_at")
  createdAt        DateTime  @default(now()) @map("created_at")

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([zaloAccountId, zaloPollId])
  @@index([orgId, groupExternalId])
  @@map("group_polls")
}

// State machine for outreach: 1 nick × 1 contact = 1 attempt
// state: queued | looking_up | no_zalo | sent | accepted | rejected | cancelled | expired | error
model FriendshipAttempt {
  id            String    @id @default(uuid())
  orgId         String    @map("org_id")
  zaloAccountId String    @map("zalo_account_id")
  contactId     String    @map("contact_id")
  state         String    @default("queued")
  zaloUidFound  String?   @map("zalo_uid_found")
  requestMsg    String?   @map("request_msg")
  errorCode     String?   @map("error_code")
  errorDetail   String?   @map("error_detail")
  queuedAt      DateTime  @default(now()) @map("queued_at")
  lookedUpAt    DateTime? @map("looked_up_at")
  sentAt        DateTime? @map("sent_at")
  decidedAt     DateTime? @map("decided_at")

  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  zaloAccount ZaloAccount  @relation(fields: [zaloAccountId], references: [id], onDelete: Cascade)
  contact     Contact      @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([zaloAccountId, contactId])
  @@index([orgId, state])
  @@index([contactId, state])
  @@index([zaloAccountId, state, queuedAt])
  @@map("friendship_attempts")
}

// Per-(nick × KH) relationship row. Created when ANY of these occur:
//   - friend request accepted (zca-js friend_event ADD) → friendshipStatus=accepted
//   - friend request sent successfully → friendshipStatus=pending_sent
//   - friend request received (zca-js friend_event REQUEST, isSelf=false) → pending_received
//   - first message exchanged with KH not yet friend → hasConversation=true, friendshipStatus=none
// Drives both /friends UI (per-nick view) and Contact aggregate counters.
model Friend {
  id                 String    @id @default(uuid())
  orgId              String    @map("org_id")
  contactId          String    @map("contact_id")
  zaloAccountId      String    @map("zalo_account_id")
  zaloUidInNick      String    @map("zalo_uid_in_nick")

  // ── State (2 dimensions + 1 derived) ────────────────────────────────────
  friendshipStatus   String    @default("none") @map("friendship_status")
                     // none | pending_sent | pending_received | accepted | rejected | removed | blocked
  hasConversation    Boolean   @default(false) @map("has_conversation")
  relationshipKind   String    @default("none") @map("relationship_kind")
                     // friend | pending_friend | chatting_stranger | ghost | none

  // ── Zalo-side metadata ──────────────────────────────────────────────────
  aliasInNick        String?   @map("alias_in_nick")
  zaloLabels         Json      @default("[]") @map("zalo_labels")          // [{id,name,color}]
  zaloLabelsSyncedAt DateTime? @map("zalo_labels_synced_at")

  // ── Lifecycle timestamps ────────────────────────────────────────────────
  becameFriendAt     DateTime? @map("became_friend_at")
  removedAt          DateTime? @map("removed_at")
  firstMessageAt     DateTime? @map("first_message_at")  // first message exchanged across this pair

  // ── Per-pair aggregates (set-if-newer / increment from message hooks) ──
  lastInboundAt      DateTime? @map("last_inbound_at")
  lastOutboundAt     DateTime? @map("last_outbound_at")
  lastInteractionAt  DateTime? @map("last_interaction_at")
  totalInbound       Int       @default(0) @map("total_inbound")
  totalOutbound      Int       @default(0) @map("total_outbound")

  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt      @map("updated_at")

  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  contact     Contact      @relation(fields: [contactId], references: [id], onDelete: Cascade)
  zaloAccount ZaloAccount  @relation(fields: [zaloAccountId], references: [id], onDelete: Cascade)

  @@unique([zaloAccountId, contactId])
  @@unique([zaloAccountId, zaloUidInNick])
  @@index([orgId, contactId])
  @@index([zaloAccountId, relationshipKind])              // /friends tab filtering
  @@index([zaloAccountId, friendshipStatus])
  @@index([orgId, relationshipKind])
  @@map("friends")
}
